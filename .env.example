# Copy to `.env` (gitignored) and fill in. NEVER commit real secrets.
# A native runtime-env loader (react-native-config) is wired in Phase 6;
# this file documents the env contract the app expects.

# Base URL of the deployed AWS API Gateway sync endpoint (from `sam deploy`).
AWS_API_BASE_URL=

# AWS region for the sync backend (Mumbai = lowest latency for Indian field ops).
AWS_REGION=ap-south-1

# Cosine-similarity threshold for a positive face match (tuned in Phase 3/7).
FACE_MATCH_THRESHOLD=0.5
